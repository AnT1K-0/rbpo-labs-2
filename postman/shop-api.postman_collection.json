{
  "info": {
    "name": "Shop API (RBPO Labs 2-4)",
    "_postman_id": "c2f0c2af-5fd6-45ff-aa3e-shop-api",
    "description": "Postman collection for RBPO Labs 2-4: CRUD, business operations, security.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get all products (public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          },
          "response": []
        },
        {
          "name": "Create product (ADMIN)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{authUsername}}", "type": "string" },
                { "key": "password", "value": "{{authPassword}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test product\",\n  \"description\": \"Created from Postman\",\n  \"price\": 100.0,\n  \"stock\": 10,\n  \"category\": {\"id\": 1}\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Checkout order (USER)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{authUsername}}", "type": "string" },
                { "key": "password", "value": "{{authPassword}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "checkout"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": 1,\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 1 }\n  ]\n}"
            }
          },
          "response": []
        },
        {
          "name": "Cancel order (USER/ADMIN)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{authUsername}}", "type": "string" },
                { "key": "password", "value": "{{authPassword}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders/1/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "1", "cancel"]
            }
          },
          "response": []
        },
        {
          "name": "Customer summary (USER/ADMIN)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{authUsername}}", "type": "string" },
                { "key": "password", "value": "{{authPassword}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders/customer/1/summary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "customer", "1", "summary"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
